#!/usr/bin/env bash
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$ROOT_DIR/lib/common.sh"

SUBCOMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$SUBCOMMAND" in
  new)
    exec "$SCRIPT_DIR/new-container.sh" "$@"
    ;;
  start)
    exec "$SCRIPT_DIR/start.sh" "$@"
    ;;
  stop)
    exec "$SCRIPT_DIR/stop.sh" "$@"
    ;;
  status|s)
    exec "$SCRIPT_DIR/status.sh" "$@"
    ;;
  list|ls)
    exec "$SCRIPT_DIR/list.sh" "$@"
    ;;
  shell)
    exec "$SCRIPT_DIR/shell.sh" "$@"
    ;;
  rebuild)
    exec "$SCRIPT_DIR/rebuild.sh" "$@"
    ;;
  rebuild-image)
    exec "$SCRIPT_DIR/rebuild-image.sh" "$@"
    ;;
  clean)
    exec "$SCRIPT_DIR/clean.sh" "$@"
    ;;
  install)
    exec "$SCRIPT_DIR/install-dotfiles.sh" "$@"
    ;;
  help|--help|-h)
    echo "Usage: dc <command> [args]"
    echo ""
    echo "Commands:"
    echo "  new <name> <scope[,scope|overlay-path...]> [--no-team] [--no-user] [host:container ...]"
    echo "                                                    Create new project"
    echo "  new <name> <scope[,scope|overlay-path...]> [--repo-path <path>] [--no-team] [--no-user]"
    echo "       [--cpus <N>] [--memory <val>] [host:container ...]"
    echo "                                                    With resource limits"
    echo "  new <name> <scope[,scope...]> [--repo-path <path>] [--no-team] [--no-user]"
    echo "       [--overlay-containerfile <file> ...] [host:container ...]"
    echo "                                                    Overlay flag form (repeatable)"
    echo "  start [name]                                      Start project(s)"
    echo "  stop [name]                                       Stop project(s)"
    echo "  list                                              List containers and status"
    echo "  status                                            Show detailed status"
    echo "  shell <name> [cmd]                                Open shell or run command"
    echo "  rebuild <name> [--rotate-keys]                    Destroy and recreate container"
    echo "  rebuild-image [all|base]                           Rebuild shared base image"
    echo "  clean [--dry-run]                                 Remove old image tags"
    echo "  install <name> <path>                             Install dotfiles"
    echo "  help                                              Show this help"
    ;;
  *)
    echo "Unknown command: $SUBCOMMAND"
    echo "Run 'dc help' for usage."
    exit 1
    ;;
esac
