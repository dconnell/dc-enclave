#!/usr/bin/env bash
# =============================================================================
# scripts/dc - The `dc` command entry point / subcommand dispatcher.
#
# Installed as an alias (alias dc='.../scripts/dc') by setup.sh. Each subcommand
# execs a dedicated script under scripts/, so adding a command means: write
# scripts/<cmd>.sh and add a case branch here (and to dc-complete.bash).
# `dc` with no args shows help.
# =============================================================================
set -euo pipefail

# Resolve the real location of this file (following symlinks) and the repo
# root. Needed because `dc` is invoked via an alias and may be symlinked.
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$ROOT_DIR/lib/common.sh"

# Default to `help` when invoked with no subcommand.
SUBCOMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$SUBCOMMAND" in
  new)
    exec "$SCRIPT_DIR/new-container.sh" "$@"
    ;;
  start)
    exec "$SCRIPT_DIR/start.sh" "$@"
    ;;
  stop)
    exec "$SCRIPT_DIR/stop.sh" "$@"
    ;;
  status|s)
    exec "$SCRIPT_DIR/status.sh" "$@"
    ;;
  list|ls)
    exec "$SCRIPT_DIR/list.sh" "$@"
    ;;
  shell)
    exec "$SCRIPT_DIR/shell.sh" "$@"
    ;;
  rebuild-container)
    exec "$SCRIPT_DIR/rebuild-container.sh" "$@"
    ;;
  rebuild-image)
    exec "$SCRIPT_DIR/rebuild-image.sh" "$@"
    ;;
  clean)
    exec "$SCRIPT_DIR/clean.sh" "$@"
    ;;
  install)
    exec "$SCRIPT_DIR/install-dotfiles.sh" "$@"
    ;;
  version|--version|-v)
    echo "dc $DC_VERSION"
    ;;
  help|--help|-h)
    exec "$SCRIPT_DIR/help.sh" "$@"
    ;;
  *)
    echo "Unknown command: $SUBCOMMAND"
    echo "Run 'dc help' for usage."
    exit 1
    ;;
esac
