#compdef dce
# =============================================================================
# scripts/_dce - Native zsh tab completion for the `dce` command.
#
# Autoloaded by zsh when `scripts/` is on fpath and `compdef _dce dce` has run
# (both wired by setup.sh for zsh users). This is real zsh completion -- not
# the bashcompinit shim -- so candidates carry descriptions and are grouped.
#
# Candidate data (project names, scopes, the hardened global-config parser) is
# shared with scripts/dce-complete.bash via lib/complete-data.sh, so discovery
# logic and the security boundary live in exactly one place.
#
# Per-subcommand grammar mirrors scripts/dce-complete.bash and the real parsers
# in scripts/*.sh.
# =============================================================================

_dce() {
  local state

  # State machine (plans/autocomplete.md Phase 3). `'1: :->subcmd'` completes
  # the subcommand at position 1; `'*:: :->args'` fires once a subcommand token
  # exists and -- critically -- re-slices $words so the command word is dropped
  # and $CURRENT is decremented. Inside _dce_dispatch, $words[1] is then the
  # subcommand and $words[2] is the first positional, so `_arguments` numbered
  # specs ('1:...', '2:...') land on the right slots. Without this reset every
  # numbered spec is off by one (the subcommand token would consume slot 1).
  #
  # No `emulate -L zsh`: the completion system already runs widgets under a
  # controlled option set, and `emulate -L zsh` here breaks `_files` (used by
  # `install` and `new --repo-path`) -- its internal directory glob miscompiles
  # under the option combination `emulate zsh` selects.
  _arguments -C \
    '1: :->subcmd' \
    '*:: :->args'

  case $state in
    subcmd) _dce_subcommands ;;
    args)   _dce_dispatch "$words[1]" ;;
  esac
  return 0
}

# Load the shared completion-data library once per shell session. All candidate
# data (subcommands, projects, scopes, and the hardened config parser) comes
# from it, so every completion path depends on it.
_dce_load_complete_data() {
  if [[ -n "${_DC_ZSH_COMPLETE_DATA_LOADED:-}" ]]; then
    return 0
  fi

  local dce_lib=""
  if [[ -n "${functions_source[_dce]:-}" ]]; then
    dce_lib="${functions_source[_dce]:A:h:h}/lib/complete-data.sh"
  fi
  if [[ -z "$dce_lib" || ! -r "$dce_lib" ]]; then
    local d
    for d in $fpath; do
      if [[ -r "$d/lib/complete-data.sh" ]]; then
        dce_lib="$d/lib/complete-data.sh"
        break
      elif [[ -r "$d/../lib/complete-data.sh" ]]; then
        dce_lib="$d/../lib/complete-data.sh"
        break
      fi
    done
  fi

  if [[ -z "$dce_lib" || ! -r "$dce_lib" ]]; then
    return 1
  fi

  # shellcheck source=/dev/null
  source "$dce_lib" || return 1
  _DC_ZSH_COMPLETE_DATA_LOADED=1
  return 0
}

# Per-subcommand dispatch. Isolated from the top-level state machine so it can
# be exercised directly (and tested without the real _arguments engine). Runs
# in the reduced $words/$CURRENT context established by the top-level *:: reset,
# so $words[1] is the subcommand and numbered specs target the right slots.
_dce_dispatch() {
  case "$1" in
    start|stop|restart)
      # Variadic projects; exclude names already typed on the line. After the
      # *:: reset, $words[1] is the subcommand and typed projects begin at
      # $words[2], so the exclude slice is words[2,CURRENT-1].
      _arguments '*:project: _dce_projects $words[2,CURRENT-1]'
      ;;
    shell)
      # One project, then a free-form command (no completion past it).
      _arguments '1:project:_dce_projects_simple'
      ;;
    editor)
      # Optional --editor <id>, then one project.
      _arguments \
        '--editor+[editor id]:editor id:_dce_editor_ids' \
        '1:project:_dce_projects_simple'
      ;;
    logs)
      _arguments \
        '1:project:_dce_projects_simple' \
        '--follow[follow log output]' \
        '-f[follow log output]' \
        '--tail+[last N lines]:N:'
      ;;
    exec)
      # Optional --root, then one project, then a free-form command.
      _arguments \
        '--root[run as uid 0 (non-interactive)]' \
        '1:project:_dce_projects_simple'
      ;;
    rm)
      _arguments \
        '1:project:_dce_projects_simple' \
        '--yes[skip confirmation]' \
        '-y[skip confirmation]' \
        '--keep-config[preserve config and secrets dir]' \
        '--keep-volumes[preserve hidden volumes]'
      ;;
    rebuild-container)
      _arguments \
        '1:project:_dce_projects_simple' \
        '--rotate-keys[generate a fresh SSH deploy key]' \
        '--inject-creds[force-inject current SSH key and git token]' \
        '--keep-hidden-volumes[preserve hidden volumes across the rebuild]' \
        '--from-snap+[recreate from snapshot dce-snap-<name>-<label>]:snapshot label:' \
        '--yes[skip the confirmation prompt]' \
        '-y[skip the confirmation prompt]'
      ;;
    snapshot)
      _dce_snapshot
      ;;
    snapshots)
      _dce_snapshots
      ;;
    install)
      # One project, then a dotfiles directory.
      _arguments \
        '1:project:_dce_projects_simple' \
        '2:dotfiles directory:_files -/'
      ;;
    rotate-token)
      _arguments '1:project:_dce_projects_simple'
      ;;
    rebuild-image)
      _arguments '1:target:_dce_rebuild_image_targets'
      ;;
    provenance)
      _arguments \
        '1:project:_dce_projects_simple' \
        '--history[show the full build timeline]' \
        '--all[show the full build timeline]'
      ;;
    clean)
      _dce_clean
      ;;
    doctor)
      _dce_doctor
      ;;
    network|net)
      _dce_network
      ;;
    config)
      _dce_config
      ;;
    new)
      _dce_new
      ;;
    extensions)
      _dce_extensions
      ;;
    # status|s, list|ls, version(-v), help(-h): no positional completion.
  esac
}

# Subcommand candidate set. Single source of truth: lib/complete-data.sh's
# dce_complete_subcommands, so adding a subcommand to scripts/dce only requires
# updating the list in one place. Uses direct compadd for robust prefix
# matching across zsh setups.
_dce_subcommands() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_subcommands)}")
  compadd -a all
}

# Complete project names, excluding the names passed as args (already present
# on the command line). Comparison is literal string equality (not a pattern),
# so project names with dots/dashes are matched exactly.
_dce_projects() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all result=()
  local a w include
  all=("${(@f)$(dce_complete_projects)}")
  for a in "${all[@]}"; do
    include=1
    for w in "$@"; do
      [[ "$a" == "$w" ]] && { include=0; break; }
    done
    (( include )) && result+=("$a")
  done
  _wanted projects expl 'project' compadd -a result
}

_dce_projects_simple() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_projects)}")
  _wanted projects expl 'project' compadd -a all
}

# `dce clean [--dry-run] [--hidden-volumes [name]] [--snapshots [name]]`: flags
# are always offered; a single optional project is offered once a scoping flag is
# active and no project has been typed yet.
_dce_clean() {
  local have_scope=0 have_proj=0 i w
  # After the *:: reset, $words[1] is the `clean` subcommand; scan its args
  # from index 2 onward.
  for ((i = 2; i < CURRENT; i++)); do
    w="${words[i]}"
    [[ "$w" == "--hidden-volumes" || "$w" == "--snapshots" ]] && have_scope=1
    if (( have_scope )) && [[ "$w" != -* ]] && (( ! have_proj )); then
      have_proj=1
    fi
  done

  local -a flags
  flags=(--dry-run --hidden-volumes --snapshots)
  _wanted flags expl 'flag' compadd -a flags
  if (( have_scope )) && (( ! have_proj )); then
    _dce_projects_simple
  fi
}

# `dce snapshot <project> [<label>] [--exclude-volumes] [--exclude-volume <p>]
# [--yes|-y]` (create) or `dce snapshot rm <project> <label>` (remove).
_dce_snapshot() {
  # `snapshot rm <project> <label>`: complete a project at the next slot; the
  # label is free-form and no create flags apply on the rm path. After the
  # top-level *:: reset, $words[1] is "snapshot", so the rm token is $words[2].
  if [[ "${words[2]}" == "rm" ]]; then
    _arguments '2:project: _dce_projects_simple'
    return 0
  fi
  _arguments \
    '1:project or rm: _dce_snapshot_first' \
    '--exclude-volumes[skip ALL hidden-volume capture]' \
    '*--exclude-volume[exclude specific hidden volume(s)]:path:' \
    '--yes[skip the confirmation prompt]' \
    '-y[skip the confirmation prompt]'
}
_dce_snapshot_first() {
  compadd rm
  _dce_projects_simple
}

# `dce snapshots list [<project>]`. Position 1 offers `list` plus project names.
_dce_snapshots() {
  _arguments '1:list or project: _dce_snapshots_first'
}
_dce_snapshots_first() {
  compadd list
  _dce_projects_simple
}

# `dce doctor [backend|project]`: one optional target (backend or project).
_dce_doctor() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_doctor_targets)}")
  _wanted targets expl 'backend or project' compadd -a all
}

# `dce new <name> [scope] [--config <file>] [--save-team] [--save-user] [--repo-path <d>] [--cpus N] [--memory V] [--hide <p>] [--network <n>[,...]] [--ip <addr>] [--yes|-y] [ports]`.
_dce_new() {
  _arguments \
    '1:project name:' \
    '2:scope:_dce_scopes' \
    '--config+[load an explicit recipe file]:recipe file:_files' \
    '--save-team[save CLI-supplied recipe keys to team container-recipes/<name>]' \
    '--save-user[save CLI-supplied recipe keys to user container-recipes/<name>]' \
    '--repo-path+[override the repos directory]:directory:_files -/' \
    '--cpus+[cpu limit (e.g. 2, 1.5)]:value:' \
    '--memory+[memory limit (e.g. 4g, 512m)]:value:' \
    '*--hide[workspace path(s) to keep in a named volume]:path:' \
    '*--network[network(s) to attach (name\[,name...\] or name:ip)]:network:' \
    '--ip+[static IPv4 for the primary network]:addr:' \
    '--yes[skip the recipe-repo-path confirmation prompt]' \
    '-y[skip the recipe-repo-path confirmation prompt]'
}

# `dce network <subaction> [args]`.
_dce_network() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a subs
  subs=("${(@f)$(dce_complete_network_subactions)}")
  _describe 'network subcommand' subs
}

# `dce config <show|get|set|sync-vscode|ls> ...`. Position 1 is the subaction;
# show/get/set/sync-vscode take a project next, get/set take a key after that,
# sync-vscode optionally takes --dry-run, and set's value is free-form.
_dce_config() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local sub="${words[2]}"
  case "$sub" in
    ls)
      _arguments '1:subcommand: _dce_config_subactions'
      ;;
    show)
      _arguments \
        '1:subcommand: _dce_config_subactions' \
        '2:project:_dce_projects_simple'
      ;;
    get)
      _arguments \
        '1:subcommand: _dce_config_subactions' \
        '2:project:_dce_projects_simple' \
        '3:key: _dce_config_keys'
      ;;
    set)
      _arguments \
        '1:subcommand: _dce_config_subactions' \
        '2:project:_dce_projects_simple' \
        '3:key: _dce_config_keys'
      ;;
    sync-vscode)
      _arguments \
        '1:subcommand: _dce_config_subactions' \
        '2:project:_dce_projects_simple' \
        '*:flag:(--dry-run)'
      ;;
    *)
      _arguments '1:subcommand: _dce_config_subactions'
      ;;
  esac
}
_dce_config_subactions() {
  local -a subs
  subs=("${(@f)$(dce_complete_config_subactions)}")
  _describe 'config subcommand' subs
}
_dce_config_keys() {
  local -a keys
  keys=("${(@f)$(dce_complete_config_keys)}")
  _wanted keys expl 'key' compadd -a keys
}

_dce_scopes() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_scopes)}")
  _wanted scopes expl 'overlay scope' compadd -a all
}

_dce_rebuild_image_targets() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_rebuild_image_targets)}")
  _wanted targets expl 'target' compadd -a all
}

_dce_editor_ids() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi

  local -a all
  all=("${(@f)$(dce_complete_editor_ids)}")
  _wanted editors expl 'editor id' compadd -a all
}

# `dce extensions <list|host|available|show|diff|capture> [project] [flags]`.
# Branches on the subaction so `host` takes no project while the others offer
# one at slot 2; --editor/--format/--scope consume a value; --user/--team/--all
# are flags. capture's trailing <id>... is free-form (not completed). Mirrors the
# per-subaction dispatch pattern used by _dce_config.
#
# Grammar assumption: the subaction is the first token after `extensions`
# ($words[2] after the *:: reset), per the documented
# `dce extensions <subcommand> [flags] <project>` form. The parser accepts
# interspersed flags, but completion is positionally rigid: a global flag typed
# before the subaction falls through to the default branch. Acceptable because
# usage convention puts the subaction first.
_dce_extensions() {
  local sub="${words[2]}"
  case "$sub" in
    host)
      # No project; flags only.
      _arguments \
        '--editor+[editor id]:editor id:_dce_extensions_editor_ids' \
        '--format+[output format]:format:(ids json manifest)'
      ;;
    capture)
      _arguments \
        '2:project:_dce_projects_simple' \
        '--editor+[editor id]:editor id:_dce_extensions_editor_ids' \
        '--format+[output format]:format:(ids json manifest)' \
        '--scope+[target scope for capture]:scope:_dce_scopes' \
        '--user[write to the user manifest root]' \
        '--team[write to the team manifest root]' \
        '--all[capture: snapshot the full container install set]'
      ;;
    show|list|available|diff)
      _arguments \
        '2:project:_dce_projects_simple' \
        '--editor+[editor id]:editor id:_dce_extensions_editor_ids' \
        '--format+[output format]:format:(ids json manifest)'
      ;;
    *)
      # No subaction committed yet (or an unknown one): offer the subaction
      # candidate set, then the flags so partial typing still completes.
      _arguments \
        '1:subcommand: _dce_extensions_subactions' \
        '--editor+[editor id]:editor id:_dce_extensions_editor_ids' \
        '--format+[output format]:format:(ids json manifest)' \
        '--scope+[target scope for capture]:scope:_dce_scopes' \
        '--user[write to the user manifest root]' \
        '--team[write to the team manifest root]' \
        '--all[capture: snapshot the full container install set]'
      ;;
  esac
}
_dce_extensions_subactions() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi
  local -a subs
  subs=("${(@f)$(dce_complete_extensions_subactions)}")
  _describe 'extensions subcommand' subs
}
_dce_extensions_editor_ids() {
  if ! _dce_load_complete_data; then
    _message "dce completion unavailable (cannot locate lib/complete-data.sh)"
    return 1
  fi
  local -a all
  all=("${(@f)$(dce_complete_extensions_editor_ids)}")
  _wanted editors expl 'editor id' compadd -a all
}
