# Optional user overlay fragment for preferred day-to-day tools.
#
# Usage examples:
#   dc new <name> nodejs,Containerfiles/Containerfile.user
#   dc new <name> nodejs --overlay-containerfile Containerfiles/Containerfile.user
#
# Notes:
# - This file is a starter. Copy it and customize as needed.
# - In overlay mode, FROM/CMD lines are ignored during composition.

USER root

# Convenience CLI tools previously baked into the base image.
RUN apt-get update && apt-get install -y \
    vim \
    jq \
    tree \
    tmux \
    rsync \
    ripgrep \
    fzf \
    less \
    unzip \
    zip \
    lsof \
    net-tools \
    iproute2 \
    iputils-ping \
    dnsutils \
    && rm -rf /var/lib/apt/lists/*

# PostgreSQL client (major-pinned where available).
ARG POSTGRES_CLIENT_MAJOR=16
RUN apt-get update && \
    if apt-cache show "postgresql-client-${POSTGRES_CLIENT_MAJOR}" >/dev/null 2>&1; then \
      apt-get install -y "postgresql-client-${POSTGRES_CLIENT_MAJOR}"; \
    else \
      echo "WARNING: postgresql-client-${POSTGRES_CLIENT_MAJOR} unavailable, installing default postgresql-client"; \
      apt-get install -y postgresql-client; \
    fi && \
    rm -rf /var/lib/apt/lists/*

# OpenCode shell installer.
USER dev
RUN curl -fsSL https://opencode.ai/install | bash
